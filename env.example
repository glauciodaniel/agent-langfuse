# Configuracao de Ambiente - O Analista Junior
# 
# INSTRUCOES:
# 1. Copie este arquivo e renomeie para .env
# 2. Substitua os valores conforme necessario
# 3. NUNCA commite o arquivo .env no Git (ele esta no .gitignore)
#
# Como obter sua chave OpenAI:
# 1. Acesse: https://platform.openai.com/api-keys
# 2. Faca login ou crie uma conta
# 3. Clique em "Create new secret key"
# 4. Copie a chave e cole abaixo

# =============================================================================
# CONFIGURACOES OBRIGATORIAS
# =============================================================================

# Chave de API da OpenAI (OBRIGATORIO)
OPENAI_API_KEY=sua-chave-aqui

# =============================================================================
# CONFIGURACOES OPCIONAIS (valores padrao ja funcionam)
# =============================================================================

# Modelo a ser usado (padrao: gpt-3.5-turbo)
# Opcoes: gpt-3.5-turbo, gpt-4, gpt-4-turbo, gpt-4o
# gpt-4 e mais capaz mas mais caro
OPENAI_MODEL=gpt-3.5-turbo

# Temperature do modelo (padrao: 0)
# 0 = mais deterministico (recomendado para tools)
# 1 = mais criativo
OPENAI_TEMPERATURE=0

# Numero maximo de tentativas em caso de erro (padrao: 3)
OPENAI_MAX_RETRIES=3

# Timeout em segundos (padrao: 30)
OPENAI_TIMEOUT=30
